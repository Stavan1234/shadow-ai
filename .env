# Shadow runtime — edit values here; config.py loads this on startup.
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
LLM_ENDPOINT=http://localhost:11434/v1
LLM_API_KEY=ollama

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
EMBEDDING_API_KEY=ollama
EMBEDDING_DIMENSIONS=768

VECTOR_DB_PROVIDER=lancedb
GRAPH_DATABASE_PROVIDER=ladybug

ENABLE_BACKEND_ACCESS_CONTROL=false
CACHING=false
COGNEE_SKIP_CONNECTION_TEST=true
HUGGINGFACE_TOKENIZER=nomic-ai/nomic-embed-text-v1.5

# Shadow tuning (optional)
SHADOW_NUM_CTX=2048
SHADOW_NUM_PREDICT=300
SHADOW_MAX_HISTORY_TURNS=10
SHADOW_MEMORY_DATASET=shadow_memory

# Cognee: leave unset to use project-local .cognee_system / .data_storage / .cognee_cache

# S.H.A.D.O.W. v4 server port mappings
LLM_CHAT_PORT=8080
LLM_BACKGROUND_PORT=8081
COGNEE_API_PORT=8002

# Wake trigger mode: 'vad' (triggers on voice start and filters transcription for 'shadow') or 'openwakeword'
SHADOW_WAKE_MODE=vad
